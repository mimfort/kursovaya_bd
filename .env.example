# Скопируйте этот файл в .env и при необходимости поменяйте значения.
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=pharmacy_admin
POSTGRES_PASSWORD=pharmacy_password_change_me
POSTGRES_DB=pharmacy_warehouse
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Порт, на котором БД будет доступна С ХОСТА (psql/DBeaver/pgAdmin).
# 5433 выбран, чтобы не конфликтовать с локально установленным PostgreSQL.
HOST_POSTGRES_PORT=5433

# --- Backend (используется на шаге 6) ---
BACKEND_PORT=8000

# --- Frontend (используется на шаге 7) ---
FRONTEND_PORT=8501
BACKEND_URL=http://backend:8000
